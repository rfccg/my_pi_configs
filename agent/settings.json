{
  "lastChangelogVersion": "0.79.4",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "terminal": {
    "showTerminalProgress": true
  },
  "packages": [
    "npm:@ff-labs/pi-fff"
  ],
  "theme": "dark",
  "skills": [
    "../pi-base/skills/superpowers/skills"
  ],
  "extensions": [
    "../pi-base/extensions/wiki",
    "../pi-base/extensions/todo",
    "../pi-base/extensions/auto-compact"
  ],
  "wiki": {
    "root": "../wiki",
    "requireConfirmation": true,
    "summaryMaxChars": 280,
    "detailsMaxChars": 5000
  },
  "compaction": {
    "enabled": true,
    "autoThreshold": 0.7
  }
}
