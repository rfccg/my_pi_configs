{
  "lastChangelogVersion": "0.79.6",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "terminal": {
    "showTerminalProgress": true
  },
  "packages": [
    "npm:@ff-labs/pi-fff"
  ],
  "theme": "dark",
  "skills": [
    "skills"
  ],
  "extensions": [
    "../pi-base/extensions/wiki",
    "../pi-base/extensions/auto-compact",
    "../pi-base/extensions/incognia-mcp"
  ],
  "subagent": {
    "implementer": {
      "enabled": true,
      "model": null
    }
  },
  "wiki": {
    "root": "../wiki",
    "requireConfirmation": true,
    "summaryMaxChars": 280,
    "detailsMaxChars": 5000
  },
  "compaction": {
    "enabled": true,
    "autoThreshold": 0.7
  }
}